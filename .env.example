# Public app URLs
WEB_PUBLIC_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production canonical domain
# NEXT_PUBLIC_SITE_URL=https://eduaipolicy.org
# WEB_PUBLIC_BASE_URL=https://eduaipolicy.org
# API_PUBLIC_BASE_URL=https://eduaipolicy.org

# Local dev data services
POSTGRES_USER=uapt
POSTGRES_PASSWORD=uapt_local_password
POSTGRES_DB=uapt
POSTGRES_PORT=5432
REDIS_PORT=6379

# Canonical data service URLs
DATABASE_URL=postgresql://uapt:uapt_local_password@localhost:5432/uapt?schema=public
DIRECT_DATABASE_URL=postgresql://uapt:uapt_local_password@localhost:5432/uapt?schema=public
REDIS_URL=redis://localhost:6379

# Limited ingestion credentials for OpenClaw, crawler agents, and the private analytics page
INGESTION_API_BASE_URL=
INGESTION_CLIENT_ID=
INGESTION_CLIENT_SECRET=
INGESTION_TOKEN=

# Crawler behavior
CRAWLER_USER_AGENT=
CRAWLER_CONTACT_EMAIL=
CRAWLER_DEFAULT_RATE_LIMIT_PER_HOST=
CRAWLER_MAX_CONCURRENCY=

# Optional external extraction and crawl helpers
FIRECRAWL_API_KEY=
LLM_PROVIDER=
LLM_API_KEY=
