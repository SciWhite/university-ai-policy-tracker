      "sourceUrl": "https://e-journal.unair.ac.id/JPERPUS/editorial_policies",
      "finalUrl": "https://e-journal.unair.ac.id/JPERPUS/editorial_policies",
      "sourceTitle": "Editorial Policies",
      "sourceLanguage": "en",
